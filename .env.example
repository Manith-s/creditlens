# Copy to .env and fill in. .env is gitignored.

# --- MLflow tracking server (local) ---
# Start it with:  make mlflow   (or see Makefile)
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# Only needed if you point MLflow at a bare file path instead of the SQLite server.
# The SQLite-backed server (recommended) does NOT need this.
# MLFLOW_ALLOW_FILE_STORE=true

# --- Spark ---
# Path to a JDK 17+ (Temurin recommended). PySpark 4.x will not start without it.
# JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64
SPARK_DRIVER_MEMORY=6g

# --- LLM provider switch for the RAG assistant ---
# "ollama" (default, local, free) or "openai" (hosted, faster demos).
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Only used when LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_LLM_MODEL=gpt-4o-mini

# --- Reproducibility ---
RANDOM_SEED=42
